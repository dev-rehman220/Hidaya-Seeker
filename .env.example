# ============================================================
# Daily Islamic Reminder — Environment Variables
# ============================================================
# Rename this file to .env.local, fill in real values, then
# restart the dev server. NEVER commit .env.local to Git.
#
# On Vercel: add these under Settings → Environment Variables.
# ============================================================

# ------------------------------------------------------------
# 1. MONGODB  (Required)
# ------------------------------------------------------------
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/hidaya-seeker?retryWrites=true&w=majority

# ------------------------------------------------------------
# 2. NEXTAUTH  (Required)
# ------------------------------------------------------------
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=replace_with_random_32_char_string

# Use your Vercel deployment URL in production (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# ------------------------------------------------------------
# 3. EMAIL / NODEMAILER  (Required for password-reset emails)
# ------------------------------------------------------------
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your@gmail.com
EMAIL_SERVER_PASSWORD=your-gmail-app-password
EMAIL_FROM=Daily Reminder <noreply@yourdomain.com>

# ------------------------------------------------------------
# 4. MANUAL DONATION PROOF UPLOAD (Cloudinary)
# ------------------------------------------------------------
# Donors upload payment screenshot proofs directly to Cloudinary.
# Create an unsigned upload preset limited to image uploads.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-unsigned-upload-preset

# ============================================================
# Daily Islamic Reminder — Environment Variables
# ============================================================
# Rename this file to .env.local, fill in real values, then
# restart the dev server. NEVER commit .env.local to Git.
#
# On Vercel: add these under Settings → Environment Variables.
# ============================================================

# ------------------------------------------------------------
# 1. MONGODB  (Required)
# ------------------------------------------------------------
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/hidaya-seeker?retryWrites=true&w=majority

# ------------------------------------------------------------
# 2. NEXTAUTH  (Required)
# ------------------------------------------------------------
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=replace_with_random_32_char_string

# Use your Vercel deployment URL in production (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# ------------------------------------------------------------
# 3. EMAIL / NODEMAILER  (Required for password-reset emails)
# ------------------------------------------------------------
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your@gmail.com
EMAIL_SERVER_PASSWORD=your-gmail-app-password
EMAIL_FROM=Daily Reminder <noreply@yourdomain.com>

# ------------------------------------------------------------
# 4. PAYMENTS (JazzCash)
# ------------------------------------------------------------
# Active provider. Leave as jazzcash unless another provider is added in code.
PAYMENT_PROVIDER=jazzcash

# JazzCash hosted checkout URL. If omitted, app falls back to /donate.
JAZZCASH_CHECKOUT_URL=https://sandbox.jazzcash.com.pk/CustomerPortal/transactionmanagement/merchantform

# Optional shared secret to validate incoming payment webhooks.
PAYMENT_WEBHOOK_SECRET=replace_with_long_random_secret

# Optional JazzCash-specific secret. If set, it takes priority over PAYMENT_WEBHOOK_SECRET.
JAZZCASH_WEBHOOK_SECRET=replace_with_long_random_secret

# ============================================================
# Daily Islamic Reminder Website – Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.

# ------------------------------------------------------------
# 1. MONGODB (Required)
# ------------------------------------------------------------
# Get a free cluster from https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/daily-reminder?retryWrites=true&w=majority

# ------------------------------------------------------------
# 2. NEXTAUTH (Required)
# ------------------------------------------------------------
# Must be a random secret string of at least 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=REPLACE_WITH_RANDOM_32_CHAR_STRING

# The base URL of your site (no trailing slash)
# Use http://localhost:3000 for local development
NEXTAUTH_URL=http://localhost:3000

# ------------------------------------------------------------
# 3. EMAIL / NODEMAILER (Required for password reset emails)
# ------------------------------------------------------------
# For Gmail: enable 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your@gmail.com
EMAIL_SERVER_PASSWORD=your-gmail-app-password
EMAIL_FROM=Daily Reminder <noreply@yourdomain.com>

# ------------------------------------------------------------
# 4. PAYMENTS (JazzCash)
# ------------------------------------------------------------
# Keep this as jazzcash for now. Future providers can be added in src/lib/payments/router.ts.
PAYMENT_PROVIDER=jazzcash

# Hosted checkout endpoint (sandbox by default).
JAZZCASH_CHECKOUT_URL=https://sandbox.jazzcash.com.pk/CustomerPortal/transactionmanagement/merchantform

# Core merchant credentials from JazzCash dashboard.
JAZZCASH_MERCHANT_ID=MCXXXXXXXX
JAZZCASH_PASSWORD=YourMerchantPassword
JAZZCASH_INTEGRITY_SALT=YourIntegritySalt

# Optional merchant routing fields (only if your JazzCash account requires them).
JAZZCASH_SUB_MERCHANT_ID=
JAZZCASH_BANK_ID=
JAZZCASH_PRODUCT_ID=

# Optional behavior/config fields.
JAZZCASH_API_VERSION=1.1
JAZZCASH_LANGUAGE=EN
JAZZCASH_TRANSACTION_CURRENCY=PKR

# Callback URL and webhook verification secrets.
# For local testing with ngrok, use your tunnel URL + /api/payments/webhook
JAZZCASH_RETURN_URL=http://localhost:3000/api/payments/webhook
PAYMENT_WEBHOOK_SECRET=replace_with_long_random_secret
JAZZCASH_WEBHOOK_SECRET=replace_with_long_random_secret
